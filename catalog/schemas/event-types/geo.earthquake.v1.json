{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentfeeds.dev/schemas/geo.earthquake.v1.json",
  "title": "Earthquake Event",
  "type": "object",
  "required": ["id", "time", "magnitude", "place"],
  "properties": {
    "id": { "type": "string" },
    "time": { "type": "string" },
    "magnitude": { "type": "number" },
    "place": { "type": "string" },
    "url": { "type": "string" }
  }
}
