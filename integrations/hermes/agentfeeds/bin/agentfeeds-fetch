#!/usr/bin/env bash
set -euo pipefail

SCRIPT="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT" ]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [[ "$SCRIPT" != /* ]] && SCRIPT="$DIR/$SCRIPT"
done
PLUGIN_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"
REPO_ROOT="$(cd "$PLUGIN_DIR/../../.." && pwd)"
exec uv run --project "$REPO_ROOT" agentfeeds-fetch "$@"
